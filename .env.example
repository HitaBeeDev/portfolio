# ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. This file is safe to commit.
# ─────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://your-name.dev

# Sentry — https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=

# ─── Project 4: SaaS Product ─────────────────────────────────────────────────

# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — https://dashboard.clerk.com/apps/<id>/instances/<id>/api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
